  "keyFeatures": [
    "Unified async vehicle control for drones and rovers via ArduPilot/MAVSDK",
    "Scriptable missions with BasicRunner and StateMachine patterns",
    "Multi-vehicle ZMQ coordination for leader/follower and swarm scenarios",
    "Built-in geofence safety checker with KML polygon support",
    "QGroundControl .plan file loading for pre-planned trajectories",
    "Non-blocking VehicleTask commands with progress tracking and cancellation",
    "AERPAW platform integration with OEO logging and checkpoints",
    "v1/v2 dual API with migration path from legacy DroneKit scripts"
  ],
