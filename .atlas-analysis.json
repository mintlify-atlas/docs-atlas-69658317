  "projectType": "sdk-library",
  "projectName": "aerpawlib",
  "projectDescription": "A Python library for controlling drones and ground vehicles within the AERPAW platform, providing async mission execution, state machines, safety checking, and multi-vehicle coordination via ArduPilot/MAVSDK.",
